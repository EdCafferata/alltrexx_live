# Kopieer dit bestand naar .env en vul de echte waarden in
# cp .env.example .env

# Database
DB_ROOT_PASSWORD=root_change_me
DB_USERNAME=alltrexx
DB_PASSWORD=alltrexx_change_me

# JWT (gebruik een lang random string in productie!)
JWT_SECRET=VeranderDitNaarEenLangGeheimWachtwoord2024!

# MarineTraffic API key
# Aanmaken op: https://www.marinetraffic.com/en/ais-api-services
MARINETRAFFIC_API_KEY=DEMO_KEY

# Apple CloudKit (accounts + trackdata — zie ONTWERP_KEUZES.md)
# API-token aanmaken: icloud.developer.apple.com → container → Settings → Tokens
# Type: API Token (géén Server-to-Server key), Sign in Callback: je site-URL
REACT_APP_CLOUDKIT_CONTAINER=iCloud.cafferata.info.alltrexx
REACT_APP_CLOUDKIT_API_TOKEN=plak-hier-je-token
REACT_APP_CLOUDKIT_ENV=development

# OpenAIP luchtvaart-overlay (vliegvelden & luchtruim) — gratis key: www.openaip.net
REACT_APP_OPENAIP_KEY=

# Vaste PRO-accounts (opake CloudKit-ID s, komma-gescheiden); leeg = geen
PRO_ACCOUNT_IDS=
